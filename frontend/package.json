{
  "name": "articleshelf-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage --exclude '**/*.integration.test.ts'",
    "test:unit:coverage:focused": "vitest run --config vitest.focused-coverage.config.ts --coverage --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run \"src/**/*.integration.test.ts\" --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vue-tsc --noEmit && vite build",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "capture:designs": "node scripts/capture-design-screenshots.mjs",
    "capture:responsive": "node scripts/capture-responsive-screenshots.mjs all",
    "capture:responsive:laptop": "node scripts/capture-responsive-screenshots.mjs laptop",
    "capture:responsive:macbook": "node scripts/capture-responsive-screenshots.mjs macbook",
    "capture:responsive:tablet": "node scripts/capture-responsive-screenshots.mjs tablet",
    "capture:responsive:mobile": "node scripts/capture-responsive-screenshots.mjs mobile"
  },
  "dependencies": {
    "dompurify": "^3.4.2",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  }
}
